{
  "name": "@harborclient/plugin-aws-sigv4",
  "type": "module",
  "scripts": {
    "release": "bash scripts/publish.sh",
    "build": "pnpm build:main && node scripts/build.mjs",
    "build:main": "esbuild src/main.ts --bundle --outfile=dist/main.js --format=esm --platform=browser --main-fields=module,main",
    "build:renderer": "node scripts/build.mjs",
    "dev": "pnpm dev:main & node scripts/build.mjs --watch",
    "dev:main": "esbuild src/main.ts --bundle --outfile=dist/main.js --format=esm --platform=browser --main-fields=module,main --watch",
    "dev:renderer": "node scripts/build.mjs --watch",
    "lint": "eslint --cache .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "screenshot": "bash scripts/render-screenshot.sh",
    "pack": "pnpm build && zip -r aws-sigv4.hcp manifest.json README.md dist",
    "sign": "node --experimental-strip-types scripts/plugin-sign.ts",
    "verify": "node --experimental-strip-types scripts/plugin-verify.ts"
  },
  "dependencies": {
    "@aws-crypto/sha256-js": "^5.2.0",
    "@harborclient/sdk": "^1.1.30",
    "@smithy/protocol-http": "^5.5.2",
    "@smithy/signature-v4": "^5.5.2"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/react": "^19.1.8",
    "esbuild": "^0.25.0",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  }
}
