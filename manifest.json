{
  "id": "com.harborclient.plugins.aws-sigv4",
  "name": "AWS SigV4",
  "version": "1.0.13",
  "author": "HarborClient",
  "description": "README.md",
  "summary": "HarborClient plugin that signs outgoing HTTP requests with AWS Signature Version 4.",
  "screenshots": [
    "screenshot.png",
    "screenshot-2.png",
    "screenshot-3.png"
  ],
  "categories": [
    "requests",
    "auth"
  ],
  "engines": {
    "harborclient": ">=1.9.0"
  },
  "renderer": "dist/renderer.js",
  "main": "dist/main.js",
  "permissions": [
    "ui",
    "storage",
    "http",
    "ipc"
  ],
  "contributes": {
    "collectionSettingsTabs": [
      {
        "id": "aws",
        "title": "AWS SigV4"
      }
    ],
    "requestTabs": [
      {
        "id": "aws",
        "title": "AWS SigV4"
      }
    ],
    "requestToolbarActions": [
      {
        "id": "sign",
        "title": "Sign request"
      }
    ],
    "commands": [
      {
        "id": "sign",
        "title": "Sign request"
      }
    ]
  }
}
